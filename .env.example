# Example environment variables (copy to .env.dev / .env.test / .env.prod as needed)
NODE_ENV=dev
BASE_URL=http://localhost:3005/api/v1
ENABLE_SWAGGER=true
ALLOW_GUEST_LOOKBOOK_WRITES=true
HTTP_BODY_LIMIT=1mb
HTTP_URLENCODED_LIMIT=1mb
TRUST_PROXY=1
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEPALIVE_TIMEOUT_MS=5000
SHUTDOWN_GRACE_MS=15000

# Firebase Admin credentials (set in real env files)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""
FIREBASE_STORAGE_BUCKET=
PUSH_ENABLED=false
MVP_MODE=false

# Test tokens
TEST_USER_TOKEN=
TEST_ADMIN_TOKEN=
TEST_OWNER_TOKEN_2=

PORT=3005

ALLOWED_ORIGINS=http://localhost:3000,https://your-admin-panel.web.app

# Rate limit policy
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=600
RATE_LIMIT_WRITE_WINDOW_MS=900000
RATE_LIMIT_WRITE_MAX=400
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=80
RATE_LIMIT_ADMIN_WINDOW_MS=900000
RATE_LIMIT_ADMIN_MAX=1200
RATE_LIMIT_ANALYTICS_WINDOW_MS=300000
RATE_LIMIT_ANALYTICS_MAX=2500

TEST_DELETE_USER_TOKEN=

PROD_ID_TOKEN=
